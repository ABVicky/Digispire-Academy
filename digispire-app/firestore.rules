rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if caller has admin or educator role
    function isAdmin() {
      return isAuth() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'educator');
    }

    // Users collection
    match /users/{userId} {
      // Any authenticated user can read their own profile
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      // Only admins can create/update/delete users
      allow write: if isAdmin();
    }

    // Batches
    match /batches/{batchId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Attendance — students can create (mark their own), all auth users can read
    match /attendance/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // QR Sessions — admins create, students read to validate
    match /qr_sessions/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Courses, Modules, Topics
    match /courses/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /modules/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /topics/{id} {
      allow read: if isAuth();
      // Students can update completedStudents array on their own
      allow update: if isAuth();
      allow create, delete: if isAdmin();
    }

    // Content/Resources
    match /content/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Portfolios
    match /portfolios/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // Marketing Arsenal (Tools)
    match /marketing_tools/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Class Sessions (Permanent logs)
    match /class_sessions/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
